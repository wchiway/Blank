#!/bin/bash

if type update-alternatives 2>/dev/null >&1; then
    # Remove previous link if it doesn't use update-alternatives
    if [ -L '/usr/bin/blank' -a -e '/usr/bin/blank' -a "`readlink '/usr/bin/blank'`" != '/etc/alternatives/blank' ]; then
        rm -f '/usr/bin/blank'
    fi
    update-alternatives --install '/usr/bin/blank' 'blank' '/opt/blank/blank' 100 || ln -sf '/opt/blank/blank' '/usr/bin/blank'
else
    ln -sf '/opt/blank/blank' '/usr/bin/blank'
fi

sed -i 's/Name=blank/Name=Blank/' '/usr/share/applications/blank.desktop'

chmod 4755 '/opt/blank/chrome-sandbox' || true
chmod +sx /opt/blank/resources/sidecar/mihomo
chmod +sx /opt/blank/resources/sidecar/mihomo-alpha

if [ -d '/opt/blank/resources/files/sub-store-frontend' ]; then
    chmod -R go-w '/opt/blank/resources/files/sub-store-frontend' 2>/dev/null || true
fi

restore_sparkle_service_if_was_running() {
    SERVICE_NAME='SparkleService'
    STATE_FILE='/run/blank/service-was-running'

    if [ ! -f "$STATE_FILE" ]; then
        return
    fi
    rm -f "$STATE_FILE" 2>/dev/null || true

    if command -v systemctl >/dev/null 2>&1; then
        systemctl start "$SERVICE_NAME" >/dev/null 2>&1 || true
    elif command -v service >/dev/null 2>&1; then
        service "$SERVICE_NAME" start >/dev/null 2>&1 || true
    elif [ -x "/etc/init.d/$SERVICE_NAME" ]; then
        "/etc/init.d/$SERVICE_NAME" start >/dev/null 2>&1 || true
    fi
}

restore_sparkle_service_if_was_running

if hash update-mime-database 2>/dev/null; then
    update-mime-database /usr/share/mime || true
fi

if hash update-desktop-database 2>/dev/null; then
    update-desktop-database /usr/share/applications || true
fi
